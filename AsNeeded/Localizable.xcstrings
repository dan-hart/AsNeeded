        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "It is not the intention of NLM to provide specific medical advice, but rather to provide users with information to better understand their health and their medicines."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
