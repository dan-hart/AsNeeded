    "If you think you may have a medical emergency, call your doctor or emergency services immediately." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إذا كنت تعتقد أنك قد تواجه حالة طبية طارئة، فاتصل بطبيبك أو بخدمات الطوارئ فورًا."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si creus que podries tenir una emergència mèdica, truca immediatament al teu metge o als serveis d'emergència."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pokud si myslíš, že by mohlo jít o lékařskou pohotovost, okamžitě zavolej svému lékaři nebo záchranné službě."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvis du tror, du har en medicinsk nødsituation, skal du straks ringe til din læge eller alarmcentralen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn du denkst, du könntest einen medizinischen Notfall haben, rufe sofort deinen Arzt oder den Notdienst an."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Αν νομίζετε ότι μπορεί να αντιμετωπίζετε ιατρικό επείγον, καλέστε αμέσως τον γιατρό σας ή τις υπηρεσίες έκτακτης ανάγκης."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you think you may have a medical emergency, call your doctor or emergency services immediately."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you think you may have a medical emergency, call your doctor or emergency services immediately."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you think you may have a medical emergency, call your GP or emergency services immediately."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si crees que puedes tener una emergencia médica, llama a tu médico o a los servicios de emergencia de inmediato."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si crees que podrías tener una emergencia médica, llama a tu médico o a los servicios de emergencia de inmediato."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اگر فکر می‌کنید ممکن است وضعیت پزشکی اضطراری داشته باشید، فوراً با پزشک یا خدمات اورژانس تماس بگیرید."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Soita välittömästi lääkärillesi tai hätänumeroon, jos epäilet lääketieteellistä hätätilaa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si tu penses être en situation d'urgence médicale, appelle immédiatement ton médecin ou les services d'urgence."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si vous pensez avoir une urgence médicale, appelez immédiatement votre médecin ou les services d'urgence."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "אם יתכן שמדובר במצב חירום רפואי, פנה מיד לרופא או לשירותי החירום."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यदि आपको लगتا है कि आपकी मेडिकल इमरजेंसी हो सकती है, तो तुरंत अपने डॉक्टर या आपातकालीन सेवाओं को कॉल करें।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ha úgy gondolod, hogy sürgős orvosi vészhelyzet áll fenn, hívd az orvosodat vagy a mentőket azonnal."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jika Anda merasa mengalami keadaan darurat medis, segera hubungi dokter atau layanan darurat."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se pensi di avere un'emergenza medica, contatta immediatamente il tuo medico o i servizi di emergenza."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "医療的緊急事態の可能性がある場合は、直ちに担当医師または救急サービスに連絡してください。"
          }
        },
        "kk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Егер өзіңіздің медициналық шұғыл жағдайыңыз болуы мүмкін деп ойласаңыз, дереу дәрігерге немесе жедел жәрдем қызметіне хабарласыңыз."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "의료 응급 상황일 수 있다고 생각되면 즉시 의사나 응급 서비스에 연락하세요."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jika anda rasa anda mungkin mengalami kecemasan perubatan, hubungi doktor atau perkhidmatan kecemasan dengan segera."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvis du tror du kan ha en medisinsk nødsituasjon, kontakt legen din eller nødetatene umiddelbart."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Als je denkt dat je een medische noodsituatie hebt, bel dan onmiddellijk je huisarts of de hulpdiensten."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeśli podejrzewasz, że możesz mieć nagły przypadek medyczny, natychmiast zadzwoń do swojego lekarza lub na pogotowie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se achar que pode estar tendo uma emergência médica, ligue para seu médico ou para os serviços de emergência imediatamente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se achares que podes estar a ter uma emergência médica, contacta imediatamente o teu médico ou os serviços de emergência."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dacă crezi că ai putea avea o urgență medicală, sună imediat medicul tău sau serviciile de urgență."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если ты думаешь, что у тебя может быть медицинская неотложная ситуация, немедленно позвони своему врачу или в службу экстренной помощи."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Om du tror att du kan ha en medicinsk nödsituation, ring din läkare eller larma sjukvården omedelbart."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "หากคุณคิดว่าอาจเป็นเหตุฉุกเฉินทางการแพทย์ ให้โทรหาแพทย์หรือบริการฉุกเฉินทันที"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
