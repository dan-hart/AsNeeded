    "Always seek the advice of your physician or another qualified health provider with any questions you may have regarding a medical condition, medication, or treatment." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اطلب دائمًا نصيحة طبيبك أو مقدم رعاية صحية مؤهل حول أي أسئلة قد تكون لديك بخصوص حالة طبية أو دواء أو علاج."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Busca sempre l'opinió del teu metge o d'un altre professional de la salut qualificat per a qualsevol dubte sobre una condició mèdica, medicació o tractament."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vždy vyhledejte radu svého lékaře nebo jiného kvalifikovaného poskytovatele zdravotní péče, pokud máte otázky týkající se zdravotního stavu, léku nebo léčby."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Søg altid råd hos din læge eller en anden kvalificeret sundhedsudbyder, hvis du har spørgsmål om en sygdom, medicin eller behandling."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bitte suche bei Fragen zu einer Erkrankung, einem Medikament oder einer Behandlung stets den Rat deiner Ärzt:in oder einer anderen qualifizierten Gesundheitsfachperson."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ζητήστε πάντα τη συμβουλή του/της ιατρού σας ή ενός άλλου εξειδικευμένου επαγγελματία υγείας για οποιεσδήποτε ερωτήσεις σχετικά με μια ιατρική πάθηση, φάρμακο ή θεραπεία."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Always seek the advice of your physician or another qualified health provider with any questions you may have regarding a medical condition, medication, or treatment."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Always seek the advice of your doctor or another qualified health professional with any questions you may have regarding a medical condition, medicine, or treatment."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Always seek the advice of your doctor or another qualified health provider with any questions you may have regarding a medical condition, medication, or treatment."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consulta siempre a tu médico u otro profesional sanitario cualificado si tienes preguntas sobre una condición médica, un medicamento o un tratamiento."
