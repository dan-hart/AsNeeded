        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Active les notifications dans Réglages pour définir des rappels de médicaments."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "אנא אפשר התראות בהגדרות כדי להגדיר תזכורות לתרופות."
