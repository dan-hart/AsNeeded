    "Please enable notifications in Settings to set medication reminders." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يرجى تفعيل الإشعارات في الإعدادات لتعيين تذكيرات الأدوية."
          }
        },
        "ca" : {
