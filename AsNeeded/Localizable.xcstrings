    "Never disregard professional medical advice or delay seeking it because of something you have read or recorded in this app." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا تتجاهل النصائح الطبية المهنية أو تؤخر طلبها بسبب ما قرأته أو سجلته في هذا التطبيق."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mai no ignoris el consell mèdic professional ni retardis la seva cerca a causa d'alguna cosa que hagis llegit o registrat en aquesta app."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nikdy nepřehlížej odborné lékařské rady ani neodkládej jejich vyhledání kvůli tomu, co sis přečetl nebo zaznamenal v této aplikaci."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ignorer aldrig professionel medicinsk rådgivning eller udsæt ikke at søge den, på grund af noget du har læst eller registreret i denne app."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ignoriere niemals fachärztlichen Rat oder verzögere die Suche danach aufgrund von etwas, das du in dieser App gelesen oder aufgezeichnet hast."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Μην αγνοείτε ποτέ επαγγελματικές ιατρικές συμβουλές ή καθυστερείτε να τις αναζητήσετε εξαιτίας κάτι που διαβάσατε ή καταγράψατε σε αυτή την εφαρμογή."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Never disregard professional medical advice or delay seeking it because of something you have read or recorded in this app."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Never disregard professional medical advice or delay seeking it because of something you have read or recorded in this app."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Never disregard professional medical advice or delay seeking it because of something you have read or recorded in this app."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nunca ignores el consejo médico profesional ni retrases su búsqueda por algo que hayas leído o registrado en esta app."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nunca ignores el consejo médico profesional ni demores en buscarlo por algo que hayas leído o registrado en esta app."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هرگز به خاطر چیزی که در این اپ خوانده‌اید یا ثبت کرده‌اید، از توصیهٔ حرفه‌ای پزشکی صرف‌نظر نکنید یا در جستجوی آن تأخیر نکنید."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Älä koskaan jätä huomiotta ammattilaisten lääketieteellistä neuvontaa tai viivytä sen hakemista tämän sovelluksen tietojen perusteella."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ne néglige jamais un avis médical professionnel et ne retardez pas une consultation à cause de quelque chose que vous avez lu ou enregistré dans cette app."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ne jamais ignorer un avis médical professionnel ni retarder une consultation en raison de quelque chose lu ou enregistré dans cette app."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "אל תתעלם מעצה רפואית מקצועית ואל תדחה פניה בגלל משהו שקראת או רשמת באפליקציה זו."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कभी भी पेशेवर चिकित्सीय सलाह को नजरअंदाज न करें या इस ऐप में पढ़ी या दर्ज की गई किसी चीज़ के कारण सलाह लेने में विलंब न करें।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Soha ne hagyd figyelmen kívül a szakmai orvosi tanácsot, és ne halaszd el az orvosi ellátást azért, amit ebben az alkalmazásban olvastál vagy rögzítettél."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jangan pernah mengabaikan nasihat medis profesional atau menunda mencarinya karena sesuatu yang Anda baca atau catat di aplikasi ini."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Non ignorare mai il parere medico professionale né ritardare la sua ricerca a causa di qualcosa che hai letto o registrato in questa app."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このアプリで読んだり記録した内容のために、専門的な医療アドバイスを無視したり受診を遅らせたりしないでください。"
          }
        },
        "kk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Бұл қосымшада оқығаныңызға немесе жазып алғаныңызға байланысты кәсіби медициналық кеңесті назардан тыс қалдырмаңыз және оны іздеуді кешіктірмеңіз."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 앱에 읽거나 기록한 내용 때문에 전문가의 의학적 조언을 무시하거나 치료를 미루지 마십시오."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jangan sekali-kali mengabaikan nasihat perubatan profesional atau menangguhkan mendapatkan rawatan kerana sesuatu yang anda baca atau rakam dalam aplikasi ini."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ikke ignorér profesjonelle medisinske råd eller utsett å søke slik hjelp på grunn av noe du har lest eller registrert i denne appen."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Negeer nooit professioneel medisch advies of stel het zoeken ervan niet uit vanwege iets dat je in deze app hebt gelezen of vastgelegd."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nigdy nie lekceważ profesjonalnej porady medycznej ani nie odkładaj jej zasięgnięcia z powodu czegoś, co przeczytałeś lub zanotowałeś w tej aplikacji."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nunca ignore o conselho médico profissional nem demore a procurá‑lo por algo que você tenha lido ou registrado neste app."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nunca ignores o aconselhamento médico profissional nem adies a sua procura por causa de algo que tenhas lido ou registado nesta app."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nu ignora niciodată sfatul medical profesionist și nu întârzia consultarea unui specialist din cauza a ceea ce ai citit sau înregistrat în această aplicație."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Никогда не пренебрегай профессиональными медицинскими советами и не откладывай их получение из‑за того, что ты прочитал или записал(а) в этом приложении."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ignorera aldrig professionella medicinska råd eller dröj inte med att söka dem på grund av något du har läst eller registrerat i den här appen."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "อย่าเพิกเฉยต่อคำแนะนำทางการแพทย์จากผู้เชี่ยวชาญหรือชะลอการขอความช่วยเหลือเพราะสิ่งที่คุณอ่านหรือบันทึกไว้ในแอปนี้"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu uygulamada okuduğunuz veya kaydettiğiniz bir şeye dayanarak profesyonel tıbbi tavsiyeyi görmezden gelmeyin veya tıbbi yardım aramayı ertelemeyin."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Không bao giờ phớt lờ lời khuyên y tế chuyên nghiệp hoặc trì hoãn việc tìm kiếm trợ giúp vì điều bạn đã đọc hoặc ghi trong ứng dụng này."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "切勿忽视专业医疗建议，或因在此应用中阅读或记录的内容而延误就医。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "切勿忽視專業醫療建議，或因為在此應用中閱讀或記錄的內容而延誤就醫。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "切勿忽視專業醫療建議，或因為在本應用中閱讀或記錄的內容而延遲尋求醫療意見。"
          }
        }
      }
    },
