    "This will permanently delete all medications and events, and restore all app settings to their original defaults. This cannot be undone." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيؤدي هذا إلى حذف جميع الأدوية والأحداث بشكل دائم، وإعادة جميع إعدادات التطبيق إلى الإعدادات الافتراضية الأصلية. لا يمكن التراجع عن ذلك."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Això eliminarà permanentment tots els medicaments i esdeveniments, i restaurarà totes les opcions de l’aplicació als valors predeterminats originals. Aquesta acció no es pot desfer."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tímto budou trvale smazány všechny léky a události a všechna nastavení aplikace budou obnovena na původní výchozí hodnoty. Toto nelze vrátit zpět."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dette vil permanent slette alle mediciner og hændelser og gendanne alle appindstillinger til deres oprindelige standarder. Dette kan ikke fortrydes."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies löscht dauerhaft alle Medikamente und Ereignisse und stellt alle App‑Einstellungen auf die ursprünglichen Standardwerte zurück. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Αυτό θα διαγράψει μόνιμα όλα τα φάρμακα και τα γεγονότα και θα επαναφέρει όλες τις ρυθμίσεις της εφαρμογής στις αρχικές τους. Αυτό δεν μπορεί να αναιρεθεί."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will permanently delete all medications and events, and restore all app settings to their original defaults. This cannot be undone."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will permanently delete all medications and events, and restore all app settings to their original defaults. This cannot be undone."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will permanently delete all medicines and events, and restore all app settings to their original defaults. This cannot be undone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto eliminará permanentemente todos los medicamentos y eventos, y restaurará todos los ajustes de la app a sus valores predeterminados. Esto no se puede deshacer."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto eliminará permanentemente todos los medicamentos y eventos, y restaurará todos los ajustes de la app a sus valores predeterminados originales. Esta acción no se puede deshacer."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "این کار تمام داروها و رویدادها را به‌طور دائم حذف کرده و همهٔ تنظیمات برنامه را به حالت پیش‌فرض بازمی‌گرداند. این عمل قابل بازگشت نیست."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tämä poistaa pysyvästi kaikki lääkkeet ja tapahtumat sekä palauttaa kaikki sovelluksen asetukset alkuperäisiin oletusarvoihin. Tätä ei voi perua."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela supprimera définitivement tous les médicaments et événements, et rétablira tous les paramètres de l'app à leurs valeurs par défaut d'origine. Cette action est irréversible."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ceci supprimera définitivement tous les médicaments et événements, et rétablira tous les réglages de l'app aux paramètres d'origine. Cela est irréversible."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "פעולה זו תמחק לצמיתות את כל התרופות והאירועים, ותשחזר את כל הגדרות האפליקציה לברירת המחדל המקורית. לא ניתן לבטל פעולה זו."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यह सभी दवाइयों और घटनाओं को स्थायी रूप से हटा देगा और ऐप की सभी सेटिंग्स को उनकी मूल डिफ़ॉल्ट पर वापस कर देगा। इसे पूर्ववत नहीं किया जा सकता।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ez véglegesen törli az összes gyógyszert és eseményt, és visszaállítja az alkalmazás beállításait az eredeti alapértékekre. Ez nem vonható vissza."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ini akan menghapus secara permanen semua obat dan acara, serta mengembalikan semua pengaturan aplikasi ke pengaturan default awal. Tindakan ini tidak dapat dibatalkan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questo eliminerà permanentemente tutti i farmaci e gli eventi e ripristinerà tutte le impostazioni dell’app ai valori predefiniti. Questa operazione non può essere annullata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これにより、すべての薬とイベントが永久に削除され、アプリの設定は元の既定値に戻ります。これは元に戻せません。"
          }
        },
        "kk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Бұл барлық дәрілерді мен оқиғаларды тұрақты түрде жояды және қосымшаның барлық баптауларын бастапқы әдепкі мәндеріне қайтарады. Бұл әрекетті болдырмау мүмкін емес."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 작업을 수행하면 모든 약물과 이벤트가 영구적으로 삭제되고 앱 설정이 원래 기본값으로 복원됩니다. 이 작업은 되돌릴 수 없습니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ini akan memadamkan secara kekal semua ubat dan acara, serta mengembalikan semua tetapan aplikasi kepada lalai asal. Tindakan ini tidak boleh dipulihkan."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dette vil permanent slette alle medisiner og hendelser, og tilbakestille alle appens innstillinger til sine opprinnelige standardinnstillinger. Dette kan ikke angres."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dit zal alle medicijnen en gebeurtenissen permanent verwijderen en alle app‑instellingen terugzetten naar de oorspronkelijke standaardinstellingen. Dit kan niet ongedaan gemaakt worden."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To będzie trwale usuwać wszystkie leki i zdarzenia oraz przywróci wszystkie ustawienia aplikacji do ich pierwotnych wartości domyślnych. Nie można tego cofnąć."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isto excluirá permanentemente todos os medicamentos e eventos e restaurará todas as configurações do app para os padrões originais. Isso não pode ser desfeito."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isto irá eliminar permanentemente todos os medicamentos e eventos e restaurar todas as definições da app para os seus valores originais. Isto não pode ser desfeito."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aceasta va șterge permanent toate medicamentele și evenimentele și va restaura toate setările aplicației la valorile implicite inițiale. Această acțiune nu poate fi anulată."
