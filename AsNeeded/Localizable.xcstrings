          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lo siento, no pude registrar tu medicación. Por favor, inténtalo de nuevo o abre AsNeeded manualmente."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lo siento, no pude registrar tu medicamento. Intenta de nuevo o abre AsNeeded manualmente."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "متأسفم، نتوانستم داروی شما را ثبت کنم. لطفاً دوباره تلاش کنید یا به‌صورت دستی AsNeeded را باز کنید."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Valitettavasti en voinut kirjata lääkettäsi. Yritä uudelleen tai avaa AsNeeded manuaalisesti."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Désolé, je n'ai pas pu enregistrer ton médicament. Réessaie ou ouvre AsNeeded manuellement."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Désolé, je n'ai pas pu consigner ton médicament. Essaie de nouveau ou ouvre AsNeeded manuellement."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "מצטער/ת — לא הצלחתי לרשום את התרופה שלך. נסה/י שוב או פתח/י את AsNeeded באופן ידני."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "क्षमा करें, मैं आपकी दवा लॉग नहीं कर पाया। कृपया पुनः प्रयास करें या मैन्युअली AsNeeded खोलें।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sajnálom, nem sikerült rögzítenem a gyógyszert. Próbáld újra, vagy nyisd meg kézzel az AsNeeded alkalmazást."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maaf, saya tidak dapat mencatat obat Anda. Silakan coba lagi atau buka AsNeeded secara manual."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spiacente, non sono riuscito a registrare il tuo farmaco. Riprova o apri AsNeeded manualmente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "申し訳ありません。薬の記録をできませんでした。もう一度お試しになるか、手動で AsNeeded を開いてください。"
          }
        },
        "kk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кешіріңіз, дәріңізді тіркей алмадым. Қайта байқап көріңіз немесе AsNeeded қолданбасын қолмен ашыңыз."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "죄송합니다. 약물 기록을 저장하지 못했습니다. 다시 시도하거나 직접 AsNeeded를 열어 주세요."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Maaf, saya tidak dapat merekod ubat anda. Sila cuba lagi atau buka AsNeeded secara manual."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beklager, jeg klarte ikke å registrere medisinen. Prøv igjen eller åpne AsNeeded manuelt."
          }
        },
        "nl" : {
          "stringUnit" : {
