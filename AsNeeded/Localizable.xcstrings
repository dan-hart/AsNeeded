    "Consult a licensed medical professional before making any changes to your medication." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "استشر مختصًا طبيًا مرخّصًا قبل إجراء أي تغييرات على أدويتك."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consulta un professional mèdic autoritzat abans de fer cap canvi a la teva medicació."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Poraď se s licencovaným zdravotnickým odborníkem, než změníš svou medikaci."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kontakt en autoriseret læge, før du ændrer din medicin."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konsultiere vor Änderungen an deinen Medikamenten eine zugelassene medizinische Fachperson."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Συμβουλέψου έναν αδειοδοτημένο ιατρό πριν κάνεις οποιεσδήποτε αλλαγές στη φαρμακευτική σου αγωγή."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consult a licensed medical professional before making any changes to your medication."
          }
        },
        "en-AU" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consult a licensed medical professional before making any changes to your medication."
          }
        },
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consult a licensed medical professional before making any changes to your medication."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consulta a un profesional médico con licencia antes de hacer cualquier cambio en tu medicación."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consulta a un profesional médico autorizado antes de hacer cualquier cambio en tu medicación."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قبل از هر تغییر در داروهای خود، با یک پزشک مجاز مشورت کنید."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kysy lääkitysmuutoksista aina luvan saaneelta terveydenhuollon ammattilaiselta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consulte un professionnel de santé agréé avant de modifier ton traitement."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consulte un professionnel de la santé autorisé avant de modifier ton traitement."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "התייעץ/י עם איש מקצוע רפואי מוסמך לפני ביצוע שינויים בתרופתך."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "कोई भी दवा बदलने से पहले लाइसेंस प्राप्त चिकित्सा पेशेवर से सलाह लें।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konzultálj engedéllyel rendelkező orvossal, mielőtt bármilyen változtatást eszközölnél a gyógyszerezéseden."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Konsultasikan dengan tenaga medis berlisensi sebelum mengubah obat Anda."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consulta un professionista medico autorizzato prima di apportare qualsiasi modifica alla tua terapia."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "薬の変更を行う前に、必ず医師などの有資格の医療専門家に相談してください。"
          }
        },
        "kk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дәрі-дәрмегіңізге қандай да бір өзгертулер енгізерден бұрын лицензияланған медициналық маманмен кеңесіңіз."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "복용 중인 약을 변경하기 전에 면허가 있는 의료 전문가와 상담하세요."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rujuk kepada profesional perubatan berlesen sebelum membuat sebarang perubahan pada ubat anda."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rådfør deg med en lisensiert helsepersonell før du gjør endringer i medisineringen din."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Raadpleeg een bevoegd medisch professional voordat je wijzigingen aan je medicatie aanbrengt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Skonsultuj się z licencjonowanym pracownikiem służby zdrowia przed wprowadzeniem zmian w lekach."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consulte um profissional de saúde licenciado antes de fazer qualquer alteração em sua medicação."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consulta um profissional de saúde licenciado antes de fazeres qualquer alteração à tua medicação."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consultă un profesionist medical autorizat înainte de a face orice schimbare la medicația ta."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Проконсультируйся с лицензированным медицинским специалистом, прежде чем вносить изменения в свои лекарства."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rådgör med en legitimerad vårdgivare innan du gör ändringar i din medicinering."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ปรึกษาผู้เชี่ยวชาญทางการแพทย์ที่ได้รับอนุญาตก่อนเปลี่ยนยาของคุณ"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "İlacınızda herhangi bir değişiklik yapmadan önce lisanslı bir sağlık uzmanına danışın."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tham khảo ý kiến chuyên gia y tế có giấy phép trước khi thay đổi thuốc của bạn."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在对用药做出任何更改前，请咨询有执照的医疗专业人员。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在更改任何藥物前，請諮詢有執照的醫療專業人員。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在更改藥物前請諮詢有執照的醫療專業人員。"
          }
        }
      }
    },
