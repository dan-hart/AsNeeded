    "Sorry, I couldn't log your medication. Please try again or open AsNeeded manually." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عذراً، لم أستطع تسجيل دوائك. حاول مرة أخرى أو افتح AsNeeded يدويًا."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ho sento, no he pogut registrar la teva medicació. Torna-ho a provar o obre AsNeeded manualment."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Omlouvám se, nepodařilo se mi zaznamenat tvůj lék. Zkus to prosím znovu nebo otevři AsNeeded ručně."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beklager, jeg kunne ikke registrere din medicin. Prøv igen eller åbn AsNeeded manuelt."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entschuldigung, ich konnte dein Medikament nicht protokollieren. Bitte versuche es erneut oder öffne AsNeeded manuell."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Λυπάμαι, δεν μπόρεσα να καταγράψω το φάρμακό σας. Προσπαθήστε ξανά ή ανοίξτε το AsNeeded χειροκίνητα."
          }
        },
        "en" : {
          "stringUnit" : {
