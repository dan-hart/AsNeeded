        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NLM không có ý định cung cấp lời khuyên y tế cụ thể, mà mong muốn cung cấp thông tin để người dùng hiểu rõ hơn về sức khỏe và thuốc men của họ."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NLM 无意提供具体的医疗建议，而是旨在为用户提供信息，以便更好地了解他们的健康状况和药物。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NLM 並非旨在提供具體的醫療建議，而是提供資訊以幫助使用者更了解自身健康與用藥情況。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NLM 並無意提供具體醫療建議，而是希望向使用者提供資訊，以便更了解他們的健康和用藥情況。"
          }
        }
