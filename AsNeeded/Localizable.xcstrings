          "stringUnit" : {
            "state" : "translated",
            "value" : "Ты уверен(а), что хочешь удалить это напоминание?"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Är du säker på att du vill ta bort den här påminnelsen?"
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "คุณแน่ใจหรือว่าต้องการลบการเตือนนี้?"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu hatırlatıcıyı silmek istediğinizden emin misiniz?"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bạn có chắc muốn xóa lời nhắc này không?"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "确定要删除此提醒吗？"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您確定要刪除這個提醒嗎？"
