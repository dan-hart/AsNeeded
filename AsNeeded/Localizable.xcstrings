        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NLM:n tarkoituksena ei ole antaa yksilöllistä lääketieteellistä neuvontaa, vaan tarjota käyttäjille tietoa, joka auttaa ymmärtämään heidän terveyttään ja lääkkeitään."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'objectif de la NLM n'est pas de fournir des conseils médicaux spécifiques, mais d'offrir aux utilisateurs des informations pour mieux comprendre leur santé et leurs médicaments."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NLM n'a pas l'intention de fournir des conseils médicaux spécifiques, mais plutôt de fournir aux utilisateurs des informations pour mieux comprendre leur santé et leurs médicaments."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "לא בכוונת NLM לספק ייעוץ רפואי ספציפי, אלא להעניק למשתמשים מידע שיעזור להם להבין טוב יותר את מצב בריאותם ואת התרופות שלהם."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NLM का उद्देश्य विशिष्ट चिकित्सा सलाह देना नहीं है, बल्कि उपयोगकर्ताओं को उनके स्वास्थ्य और दवाओं को बेहतर समझने के लिए जानकारी प्रदान करना है।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Az NLM célja nem az, hogy konkrét orvosi tanácsot adjon, hanem hogy információt nyújtson a felhasználóknak egészségük és gyógyszereik jobb megértéséhez."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NLM tidak bermaksud memberikan saran medis khusus, melainkan menyediakan informasi agar pengguna lebih memahami kesehatan dan obat mereka."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NLM non intende fornire consigli medici specifici, ma piuttosto offrire agli utenti informazioni per comprendere meglio la propria salute e i propri farmaci."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NLMは特定の医療アドバイスを提供することを意図しているわけではなく、利用者が自身の健康や薬について理解を深めるための情報を提供することを目的としています。"
          }
        },
        "kk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NLM-нің мақсаты нақты медициналық кеңес беру емес; оның орнына пайдаланушыларға олардың денсаулығы мен қолданатын дәрілерін жақсырақ түсінуге көмектесетін ақпарат ұсыну."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NLM의 의도는 특정 의학적 조언을 제공하는 것이 아니라 사용자가 자신의 건강과 약물에 대해 더 잘 이해할 수 있도록 정보를 제공하는 것입니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bukan niat NLM untuk memberikan nasihat perubatan khusus, tetapi untuk memberikan maklumat kepada pengguna supaya mereka lebih memahami kesihatan dan ubat-ubatan mereka."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Det er ikke NLMs intensjon å gi spesifikke medisinske råd, men heller å gi brukerne informasjon for å bedre forstå helsen sin og medisinene sine."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Het is niet de bedoeling van NLM om specifieke medische adviezen te geven, maar eerder gebruikers informatie te bieden om hun gezondheid en hun medicijnen beter te begrijpen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NLM nie ma na celu udzielania konkretnych porad medycznych, lecz dostarczenie użytkownikom informacji, które pomogą lepiej zrozumieć ich zdrowie i ich leki."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Não é intenção do NLM fornecer aconselhamento médico específico, mas sim fornecer aos usuários informações para melhor entender sua saúde e seus medicamentos."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A intenção da NLM não é fornecer conselhos médicos específicos, mas sim dar aos utilizadores informações para melhor compreender a sua saúde e os seus medicamentos."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NLM nu intenționează să ofere sfaturi medicale specifice, ci să furnizeze utilizatorilor informații pentru a-și înțelege mai bine sănătatea și medicamentele."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NLM не стремится давать конкретные медицинские рекомендации; его задача — дать пользователям информацию, которая поможет лучше понять своё здоровье и препараты."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Det är inte NLM:s avsikt att ge specifika medicinska råd, utan snarare att ge användare information för att bättre förstå sin hälsa och sina läkemedel."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NLM มิได้มีเจตนาที่จะให้คำปรึกษาทางการแพทย์เฉพาะกรณี แต่มีจุดประสงค์เพื่อให้ข้อมูลแก่ผู้ใช้เพื่อเข้าใจสุขภาพและยาของตนได้ดียิ่งขึ้น"
